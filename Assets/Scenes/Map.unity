  m_text: "\u0414\u0432\u0435\u0440\u044C \u0441 \u0432\u044B\u0435\u043C\u043A\u043E\u0439
    \u0432 \u0432\u0435\u0440\u0445\u043D\u0435\u0439 \u0447\u0430\u0441\u0442\u0438(\u043F\u043E\u0432\u0435\u0440\u043D\u0443\u0442\u0430
    \u0447\u0443\u0442\u044C \u0431\u043E\u043A\u043E\u043C \u0432 \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u0435,
    \u0447\u0442\u043E\u0431\u044B \u0431\u044B\u043B\u043E \u0432\u0438\u0434\u043D\u043E
    \u0432\u044B\u0435\u043C\u043A\u0443). \u041D\u0430\u0434\u043E \u0441\u043E\u0437\u0434\u0430\u0442\u044C
    \u0440\u044F\u0434\u043E\u043C \u043E\u0431\u044C\u0435\u043A\u0442 \u043F\u043E
    \u0444\u043E\u0440\u043C\u0435 \u0432\u044B\u0435\u043C\u043A\u0438 \u043E\u0440\u0430\u043D\u0436\u0435\u0432\u043E\u0433\u043E
    \u0446\u0432\u0435\u0442\u0430, \u0447\u0442\u043E\u0431\u044B \u043E\u043D\u0430
    \u043E\u0442\u043A\u0440\u044B\u043B\u0430\u0441\u044C"
