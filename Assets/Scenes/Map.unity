      m_Calls: []
  m_text: "\u041A\u043B\u0435\u0442\u043A\u0430, \u043E\u043D\u0430 \u043E\u043F\u0443\u0441\u0442\u0438\u0442\u044C\u0441\u044F
    \u043D\u0430 \u0438\u0433\u0440\u043E\u043A\u0430 \u0441\u043D\u0438\u0437\u0443
    \u043A\u0430\u043A \u0442\u043E\u043B\u044C\u043A\u043E \u043E\u043D \u043F\u043E\u0434\u043D\u0438\u043C\u0435\u0442
    \u0447\u0435\u0440\u043D\u044B\u0439 \u0446\u0432\u0435\u0442 \u0438 \u043F\u043E\u0434\u043D\u0438\u043C\u0435\u0442
    \u0435\u0435 \u043D\u0430\u0434 \u0437\u0435\u043C\u043B\u0435\u0439. \u0423
    \u043A\u043B\u0435\u0442\u043A\u0438 \u0440\u0430\u0437\u0440\u0443\u0448\u0430\u044E\u0449\u0438\u0439\u0441\u044F
    \u043F\u043E\u043B(\u043B\u043E\u043C\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0434
    \u0442\u044F\u0436\u0435\u043B\u043E\u0439(\u0447\u0435\u0440\u043D\u043E\u0439)
    \u0444\u0438\u0433\u0443\u0440\u043E\u0439. \u041F\u043E\u043B \u0443 \u043A\u043B\u0435\u0442\u043A\u0438
    \u0438\u043C\u0435\u0435\u0442 \u043E\u0441\u043E\u0431\u0443\u044E \u0442\u0435\u043A\u0441\u0442\u0443\u0440\u0443(\u0442\u0440\u0435\u0449\u0438\u043D\u044B)"
